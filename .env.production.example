# ===========================================================================
#  PRODUCTION .env  —  Amader Somaj (amadersomaj.org)
#  Copy this to ".env" on the server (in the APP ROOT, one level above public/).
#  Fill in the cPanel MySQL credentials. Keep this file SECRET (never commit .env).
# ===========================================================================

APP_NAME="Amader Somaj"
APP_ENV=production
# A ready-to-use key was generated for you. You may keep it or replace it.
APP_KEY=base64:Znet/LKP3fZLgpMO9CjlFtheQew+FZyq73KNkCgIY4M=
APP_DEBUG=false
APP_TIMEZONE=Asia/Dhaka
APP_URL=https://amadersomaj.org

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# --- MySQL from cPanel (names are usually prefixed with your cPanel username) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cpaneluser_amadersomaj
DB_USERNAME=cpaneluser_amader
DB_PASSWORD=YOUR_STRONG_DB_PASSWORD

# These work out of the box because migrations create the sessions/cache/jobs tables.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

# --- Email: use your cPanel mailbox SMTP so contact/admin mails send ---
MAIL_MAILER=smtp
MAIL_HOST=mail.amadersomaj.org
MAIL_PORT=465
MAIL_USERNAME=info@amadersomaj.org
MAIL_PASSWORD=YOUR_MAILBOX_PASSWORD
MAIL_SCHEME=smtps
MAIL_FROM_ADDRESS="info@amadersomaj.org"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
